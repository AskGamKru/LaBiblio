@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
    var blogs = Model.Children<BooksItem>().OrderByDescending(x => x.CreateDate);
}

<!-- Blog -->
                <div class="col-md-12 blog-holder">
                    <div class="row">
                        @foreach (var item in blogs)
                        {
                            string author = item.Value<string>("author");
                            if (item.Value<string>("author") == "" || item.Value("author") == null) { author = "Anonymous"; };
                            <!-- Blog Item -->
                            <div class="col-md-4 blog-item-wrapper">
                                <div class="blog-item">
                                    <div class="blog-img">
                                        <a href="@item.Url()">
                                            <img src="@item.Image.Url()" alt="">
                                        </a>
                                    </div>
                                    <div class="blog-text">
                                        <div class="blog-tag">
                                            <h6><small>@String.Join(" | ", item.Category)</small></h6>
                                        </div>
                                        <div class="blog-title">
                                            <a href="/"><h4>@item.Name</h4></a>
                                        </div>
                                        <div class="blog-meta">
                                            <p class="blog-date">@item.CreateDate.ToString("MMMM dd, yyyy")</p>
                                        </div>
                                        <div class="blog-desc">
                                            <p>@item.Summary</p>
                                        </div>
                                        <div class="blog-author">
                                            <p>by @author</p>
                                        </div>
                                        <div class="blog-share-wrapper">
                                            <a class="blog-share" href="https://www.facebook.com/">
                                                <i class="fab fa-facebook-square"></i>
                                            </a>
                                            <a class="blog-share" href="https://www.twitter.com/">
                                                <i class="fab fa-twitter-square"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- End of Blog Item -->
                        }
                    </div>
                </div>
                <!-- End of Blog -->