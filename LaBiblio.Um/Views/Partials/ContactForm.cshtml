@using LaBiblio.Um.Controllers;
@model LaBiblio.Um.ViewModels.ContactFormViewModel

@using (Html.BeginUmbracoForm<ContactFormSurfaceController>(nameof(ContactFormSurfaceController.Submit)))
{
	@if (TempData["success"] == null)
	{

		<section id="single-content" class="bg-white">
			<div class="container">
				<div class="section-content blog-content">
					<div class="row">
						<div class="col-md-8 offset-md-2 mt-4">
							<div class="input-group">
								<label asp-for="Name"></label>
								<input asp-for="Name" />
								<span asp-validation-for="Name" class="text-danger"></span>
							</div>

							<div>
								<label asp-for="Email"></label>
								<input asp-for="Email" />
								<span asp-validation-for="Email" class="text-danger"></span>
							</div>

							<div>
								<label asp-for="Subject"></label>
								<input asp-for="Subject" />
								<span asp-validation-for="Subject" class="text-danger"></span>
							</div>

							<div>
								<label asp-for="Message"></label>
								<textarea asp-for="Message"></textarea>
								<span asp-validation-for="Message" class="text-danger"></span>
							</div>

							<input type="submit" name="Submit" value="Submit" />
							<br />
						</div>
					</div>
				</div>
			</div>
		</section>
	}
	else
	{
		<p>Thank you for contacting us. We’ll be in touch soon!</p>
	}

}